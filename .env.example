# --------------------------------------------------------------------------- #
# Copy to .env and fill in. Nested settings use the `__` delimiter.            #
# --------------------------------------------------------------------------- #

# Telegram (required) — get api_id/api_hash at https://my.telegram.org and the
# bot token from @BotFather. ADMIN_ID is the numeric Telegram user id of the
# single admin (seeded on startup and notified of errors).
TELEGRAM__API_ID=
TELEGRAM__API_HASH=
TELEGRAM__BOT_TOKEN=
TELEGRAM__ADMIN_ID=
# Optional:
# TELEGRAM__SESSION_NAME=bot
# TELEGRAM__WORKDIR=.pyrogram

# Database (optional; defaults to a local SQLite file)
# DATABASE__URL=sqlite+aiosqlite:///data/bot.db
# DATABASE__ECHO=false

# Logging (optional)
# LOGGING__LEVEL=INFO
# LOGGING__FORMAT=console   # console | json
